{
  "name": "clayton",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npx --yes -p node@22 node node_modules/expo/bin/cli start --port 8081",
    "phone": "npx --yes -p node@22 node node_modules/expo/bin/cli start --lan --port 8081",
    "phone:tunnel": "npx --yes -p node@22 node node_modules/expo/bin/cli start --tunnel --port 8081",
    "typecheck": "tsc --noEmit",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
